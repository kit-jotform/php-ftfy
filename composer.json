{
    "name": "php-ftfy/ftfy",
    "description": "Fixes text for you — PHP port of the Python ftfy library",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-mbstring": "*",
        "ext-intl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Ftfy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ftfy\\Tests\\": "tests/"
        }
    }
}
